NODE_ENV=development
APP_PORT=5000
CLIENT_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info
ALLOW_CROSS_ORIGIN_COOKIES=false
# Express "trust proxy" setting. Controls how req.ip resolves x-forwarded-for.
# Set to the exact number of trusted proxy hops (e.g. 1) or a proxy subnet.
# Do NOT use "true" in production — it lets any client spoof the logged IP.
TRUST_PROXY=loopback

DB_URL=mongodb://localhost:27017
DB_NAME=web-app-store

REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ID_SECRET=change-me

USERNAME_EMAIL=
PASSWORD_EMAIL=
