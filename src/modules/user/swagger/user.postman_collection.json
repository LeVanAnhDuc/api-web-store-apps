{
  "info": {
    "name": "User Profile API",
    "description": "Test scenarios for User Profile endpoints: GET /users/me, PATCH /users/me, POST /users/me/avatar, GET /users/:id",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "idToken",
      "value": "your-id-token-here",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "64f1b2c3d4e5f6a7b8c9d0e1",
      "type": "string"
    },
    {
      "key": "myUserId",
      "value": "your-own-user-id-here",
      "type": "string",
      "description": "The userId from your own auth token — used for TC-04.3"
    }
  ],
  "item": [
    {
      "name": "GET /users/me - Get My Profile",
      "item": [
        {
          "name": "TC-01.1 Happy - Get full profile with valid token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Expect: 200 with _id, fullName, phone, avatar, address, dateOfBirth, gender, email, createdAt"
          }
        },
        {
          "name": "TC-01.2 Happy - Profile with null optional fields",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Use a user that has not set phone/address/dateOfBirth/avatar. Expect: 200, optional fields are null"
          }
        },
        {
          "name": "TC-01.4 Error - No Authorization header",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Expect: 401 Unauthorized"
          }
        },
        {
          "name": "TC-01.5 Error - Tampered token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.invalid.signature"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Expect: 401 Unauthorized"
          }
        }
      ]
    },
    {
      "name": "PATCH /users/me - Update My Profile",
      "item": [
        {
          "name": "TC-02.1 Happy - Update fullName only",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Nguyen Van A\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Expect: 200, fullName updated, other fields unchanged"
          }
        },
        {
          "name": "TC-02.2 Happy - Update all fields",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Nguyen Van B\",\n  \"phone\": \"+84 912 345 678\",\n  \"address\": \"123 Le Loi, District 1, Ho Chi Minh City\",\n  \"dateOfBirth\": \"1995-06-15\",\n  \"gender\": \"male\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Expect: 200, all fields updated"
          }
        },
        {
          "name": "TC-02.3 Happy - Update gender only",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gender\": \"female\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Expect: 200, only gender changes"
          }
        },
        {
          "name": "TC-02.4 Edge - Empty phone string",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Expect: 422 Validation Error - phone cannot be empty"
          }
        },
        {
          "name": "TC-02.5 Edge - Empty body {}",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Expect: 200, no fields changed"
          }
        },
        {
          "name": "TC-02.6 Edge - Future dateOfBirth",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dateOfBirth\": \"2030-01-01\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Expect: 422 Validation Error - date cannot be in the future"
          }
        },
        {
          "name": "TC-02.7 Edge - dateOfBirth > 100 years ago",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dateOfBirth\": \"1900-01-01\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Expect: 422 Validation Error - age exceeds 100 years"
          }
        },
        {
          "name": "TC-02.8 Edge - fullName too short (< 2 chars)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"A\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Expect: 422 Validation Error - fullName min 2 characters"
          }
        },
        {
          "name": "TC-02.9 Edge - Invalid gender enum",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gender\": \"alien\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Expect: 422 Validation Error - gender must be male|female|other|prefer_not_to_say"
          }
        },
        {
          "name": "TC-02.10 Edge - Unknown field (email) is ignored",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newemail@hacker.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Expect: 200, email field is stripped and NOT updated"
          }
        },
        {
          "name": "TC-02.11 Error - No Authorization header",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test User\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Expect: 401 Unauthorized"
          }
        }
      ]
    },
    {
      "name": "PATCH /admin/users/:id/lock - Lock User (admin)",
      "item": [
        {
          "name": "TC-05.1 Happy - Lock another user's account",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{userId}}/lock",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{userId}}", "lock"]
            },
            "description": "Expect: 200 with { _id, isActive: false }"
          }
        },
        {
          "name": "TC-05.2 Idempotent - Lock an already-locked account",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{userId}}/lock",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{userId}}", "lock"]
            },
            "description": "Call twice in a row. Expect: 200 both times, no error"
          }
        },
        {
          "name": "TC-05.3 Error - Admin locks their own account",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{myUserId}}/lock",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{myUserId}}", "lock"]
            },
            "description": "Set {{myUserId}} to your own user ID. Expect: 403 ADMIN_CANNOT_LOCK_SELF"
          }
        },
        {
          "name": "TC-05.4 Error - Non-admin caller",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{userId}}/lock",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{userId}}", "lock"]
            },
            "description": "Use a non-admin idToken. Expect: 403 Forbidden"
          }
        },
        {
          "name": "TC-05.5 Edge - Invalid ObjectId format",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/users/abc123/lock",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "abc123", "lock"]
            },
            "description": "Expect: 400 Bad Request - Invalid user ID format"
          }
        },
        {
          "name": "TC-05.6 Edge - Valid ObjectId but user not found",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/users/000000000000000000000000/lock",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "000000000000000000000000", "lock"]
            },
            "description": "Expect: 404 Not Found"
          }
        },
        {
          "name": "TC-05.7 Error - No Authorization header",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{userId}}/lock",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{userId}}", "lock"]
            },
            "description": "Expect: 401 Unauthorized"
          }
        }
      ]
    },
    {
      "name": "PATCH /admin/users/:id/unlock - Unlock User (admin)",
      "item": [
        {
          "name": "TC-06.1 Happy - Unlock a locked account",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{userId}}/unlock",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{userId}}", "unlock"]
            },
            "description": "Expect: 200 with { _id, isActive: true }"
          }
        },
        {
          "name": "TC-06.2 Idempotent - Unlock an already-active account",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{userId}}/unlock",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{userId}}", "unlock"]
            },
            "description": "Call twice in a row. Expect: 200 both times, no error"
          }
        },
        {
          "name": "TC-06.3 Happy - Admin unlocks their own account",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{myUserId}}/unlock",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{myUserId}}", "unlock"]
            },
            "description": "Set {{myUserId}} to your own user ID. Expect: 200 (self-unlock is allowed)"
          }
        },
        {
          "name": "TC-06.4 Error - Non-admin caller",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{userId}}/unlock",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{userId}}", "unlock"]
            },
            "description": "Use a non-admin idToken. Expect: 403 Forbidden"
          }
        },
        {
          "name": "TC-06.5 Edge - Valid ObjectId but user not found",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/users/000000000000000000000000/unlock",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "000000000000000000000000", "unlock"]
            },
            "description": "Expect: 404 Not Found"
          }
        }
      ]
    },
    {
      "name": "GET /users/:id - Get Public Profile",
      "item": [
        {
          "name": "TC-04.1 Happy - Guest gets public profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}"]
            },
            "description": "Expect: 200, returns only { _id, fullName, avatar, gender }. No email, phone, address."
          }
        },
        {
          "name": "TC-04.2 Happy - Authenticated user gets another user's public profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}"]
            },
            "description": "Expect: 200, returns only public fields (NOT full profile even with valid token)"
          }
        },
        {
          "name": "TC-04.3 Edge - Authenticated user queries their own ID via public endpoint",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{idToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/{{myUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{myUserId}}"]
            },
            "description": "Set {{myUserId}} to your own user ID. Expect: 200 with only public fields (_id, fullName, avatar, gender) — NOT the full profile with email/phone/address."
          }
        },
        {
          "name": "TC-04.4 Edge - User with no avatar set",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}"]
            },
            "description": "Use the ID of a user that has never uploaded an avatar. Expect: 200, avatar field is null."
          }
        },
        {
          "name": "TC-04.5 Edge - Valid ObjectId but user not found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/000000000000000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["users", "000000000000000000000000"]
            },
            "description": "Expect: 404 Not Found"
          }
        },
        {
          "name": "TC-04.6 Edge - Invalid ObjectId format",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/abc123",
              "host": ["{{baseUrl}}"],
              "path": ["users", "abc123"]
            },
            "description": "Expect: 400 Bad Request - Invalid user ID format"
          }
        }
      ]
    }
  ]
}
